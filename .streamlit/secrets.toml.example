# Copy this file to .streamlit/secrets.toml for local use.
# For HF Spaces: add each key under Settings → Variables and secrets.
#
# FRED API keys are free: https://fredaccount.stlouisfed.org/apikeys
# Supabase connection string: Project Settings → Database → Connection string (URI mode)

FRED_API_KEY = "your_fred_api_key_here"

# Supabase PostgreSQL connection string
# Format: postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres
DATABASE_URL = "postgresql://postgres:your_password@db.your-project-ref.supabase.co:5432/postgres"
